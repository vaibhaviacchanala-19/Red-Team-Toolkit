PORT=3001
NODE_ENV=production
MONGODB_URI=mongodb://localhost:27017/redteamtoolkit

# Threat intelligence API keys
VT_API_KEY=your_virustotal_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# Scanner binaries and limits
# On Windows, wrap absolute paths in single quotes so backslashes are not escaped.
# Example: NUCLEI_BIN='C:\path\to\nuclei.exe'
NMAP_BIN=nmap
NMAP_TOP_PORTS=100
NMAP_TIMEOUT_MS=75000
NMAP_HOST_TIMEOUT=60s
NMAP_ENABLE_VULN_SCRIPTS=true
NMAP_SCRIPTS=vuln

NUCLEI_BIN=nuclei
NUCLEI_SEVERITIES=low,medium,high,critical
NUCLEI_RATE_LIMIT=30
NUCLEI_TEMPLATE_TIMEOUT=8
NUCLEI_TIMEOUT_MS=120000
# NUCLEI_TEMPLATES=/root/nuclei-templates

WHATWEB_BIN=whatweb
WHATWEB_TIMEOUT_MS=25000

# Set to true only when scanning private/internal assets you are authorized to test.
ALLOW_PRIVATE_TARGETS=false
